<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE configuration>

<configuration>
	<property name="CONSOLE_LOG_PATTERN" value="%date{HH:mm:ss.SSS} [%thread] %highlight(%-5level) %cyan(%logger{36}) -%kvp- %msg%n"/>
	<property name="CONSOLE_LOG_PATTERN_COLORIZED" value="%green(%date{HH:mm:ss.SSS}) %yellow([%thread]) %highlight(%-5level) %cyan(%logger{36}) -%kvp- %msg%n"/>

	<appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
		<encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
			<pattern>${CONSOLE_LOG_PATTERN_COLORIZED}</pattern>
			<charset>UTF-8</charset>
		</encoder>
	</appender>

	<root level="debug">
		<appender-ref ref="STDOUT" />
	</root>
</configuration>